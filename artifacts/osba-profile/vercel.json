{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build --if-present || npm run build",
  "outputDirectory": "dist/public",
  "installCommand": "npm install --legacy-peer-deps",
  "framework": null,
  "env": [
    "NODE_VERSION=22"
  ],
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
